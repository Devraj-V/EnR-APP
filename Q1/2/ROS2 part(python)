import rclpy
from rclpy.node import Node
from std_msgs.msg import String
import serial

class UARTSender(Node):                #create ROS2 node
    def __init__(self):
        super().__init__('uart_sender')

        #open serial port
        self.ser = serial.Serial('/dev/ttyUSB0', 115200, timeout=1)  #115200 is generally supported baud rate in most devices, so I used it here
        self.subscription = self.create_subscription(String,'Topic_name',self.callback,10) 

    def callback(self, msg):
        data = msg.data + '\n'  
        self.ser.write(data.encode())

        self.get_logger().info(f"Sent: {msg.data}")

def main():
    rclpy.init()
    node = UARTSender()
    rclpy.spin(node)

    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()
